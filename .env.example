PORT=8989
PROD=false
DB_PATH=monitor.db
LOG_PATH=/var/log/caddy/access.log
CADDY_ADMIN_URL=http://localhost:2019
AUTH_USER=admin
AUTH_PASS=changeme
RETENTION_DAYS=90
LOG_API_KEY=changeme-log-key
DISCORD_WEBHOOK_URL=
GEOIP_DB_PATH=GeoLite2-City.mmdb
# Comma-separated hosts to exclude from logging (e.g. monitor's own hostname)
IGNORE_HOSTS=monitor.yourdomain.com
# Comma-separated user-agent substrings to exclude (e.g. uptime pings)
IGNORE_USER_AGENTS=Go-http-client
# Log shipping to monitor portal (set both to enable)
MONITOR_URL=
MONITOR_API_KEY=

